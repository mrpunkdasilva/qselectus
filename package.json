{
  "name": "qselectus",
  "version": "1.0.0",
  "description": "A lightweight JavaScript library that simplifies DOM element selection and provides reactive state management for frontend development",
  "main": "index.js",
  "scripts": {
    "test": "jest --passWithNoTests",
    "lint": "eslint .",
    "build": "webpack --mode production",
    "prepare": "husky install",
    "prepublishOnly": "npm run test && npm run lint && npm run build",
    "docker:build": "docker build -t qselectus .",
    "docker:run": "docker run -it --rm qselectus",
    "docker:compose": "docker-compose up",
    "docker:compose:build": "docker-compose up --build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrNullus/qselectus"
  },
  "keywords": [
    "querySelector",
    "HTML",
    "JS",
    "frontend",
    "DOM",
    "selector",
    "elements",
    "state-management",
    "reactive",
    "store",
    "framework-agnostic",
    "UI"
  ],
  "author": "MrNullus",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.22.5",
    "babel-loader": "^9.1.2",
    "eslint": "^8.42.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "webpack": "^5.86.0",
    "webpack-cli": "^5.1.4"
  }
}
